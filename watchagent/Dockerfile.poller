FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .

RUN pip install --no-cache-dir \
        fastapi \
        "uvicorn[standard]" \
        sqlalchemy \
        psycopg2-binary \
        alembic \
        pydantic-settings \
        httpx \
        tenacity \
        structlog

COPY app/ app/

CMD ["python", "-m", "app.poller_main"]
